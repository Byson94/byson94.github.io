---
import { Icon } from 'astro-icon/components';
import WindowFrame from './WindowFrame.astro';

const navLinks = [
    { label: "About", dclass: "about-win" },
    { label: "Skills", dclass: "skills-win" },
    { label: "Projects", dclass: "projects-win" },
];

const socials = [
    { icon: "mdi:github", label: "Github", href: "https://github.com/Byson94" },
    { icon: "mdi:reddit", label: "Reddit", href: "https://reddit.com/user/Byson94_dev" },
    { icon: "mdi:twitter", label: "Twitter", href: "https://x.com/Byson94" },
    { icon: "mdi:email", label: "Email", href: "mailto:byson94wastaken@gmail.com" },
];
---

<aside class="hero" id="window">
    <WindowFrame disableClose={true} label="bootstrap" />

    <div class="tui-box">
        <p class="tui-box-title">[ aboutfetch ]</p>
        <div class="flex items-baseline gap-2">
            <p class="hero-name">Byson94</p>
            <p class="hero-position">~ Student</p>
        </div>
        <p class="hero-tagline">I work on Linux tooling & low-level systems</p>
        <div class="fetch-stats">
            <p><span class="fetch-key">os</span><span class="fetch-sep">:</span> Arch Linux</p>
            <p><span class="fetch-key">ed</span><span class="fetch-sep">:</span> NeoVim</p>
            <p><span class="fetch-key">sh</span><span class="fetch-sep">:</span> zsh</p>
        </div>
    </div>

    <nav class="tui-box hero-nav">
        <p class="tui-box-title">[ navigate ]</p>
        {navLinks.map(link => (
            <button class="nav-link" data-target={link.dclass}>
                <span class="nav-arrow">-&gt;</span> {link.label}
            </button>
        ))}
    </nav>

    <div class="hero-socials">
        {socials.map((s, i) => (
        <>
        <a href={s.href} class="social-link" target="_blank" rel="noopener noreferrer" aria-label={s.label}>
            <Icon name={s.icon} />
        </a>
        {i < socials.length - 1 && <span class="social-sep">│</span>}
        </>
        ))}
    </div>

</aside>

