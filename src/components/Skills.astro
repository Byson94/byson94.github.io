---
import WindowFrame from './WindowFrame.astro';

const skills = [
  {
    category: "Languages",
    items: ["Rust", "C++", "Python", "JavaScript"],
  },
  {
    category: "Web",
    items: ["Astro", "Vue", "HTML", "CSS"],
  },
  {
    category: "DevOps",
    items: ["Git", "GitHub", "GitHub Actions", "Docker"],
  },
  {
    category: "Database",
    items: ["Supabase", "Firebase", "MongoDB"],
  },
];
---

<div class="window skills-win" id="window">
    <WindowFrame navItem="skills-win" />

    <div class="content-area">
        <table class="skills-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Skills</th>
                </tr>
            </thead>
            <tbody>
                {skills.map(row => (
                <tr>
                    <td class="skill-category">{row.category}</td>
                    <td class="skill-items">{row.items.join(" · ")}</td>
                </tr>
                ))}
            </tbody>
        </table>
    </div>
</div>
