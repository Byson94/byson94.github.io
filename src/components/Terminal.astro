---
import "../styles/miniapps.css";
---

<div class="terminal-container" id="terminal">
  <div class="terminal-body" id="terminal-body"></div>
</div>

<script type="module">
  import init, { Psh } from '/psh/pkg/psh.js';

  await init();
  const shell = new Psh();

  const body = document.getElementById('terminal-body');
  const terminal = document.getElementById('terminal');

  let currentLine = null;
  let buffer = '';

  function appendLine(text) {
    const line = document.createElement('pre');
    line.className = 'terminal-line';
    line.textContent = text;
    body.appendChild(line);
  }

  function newPrompt() {
    buffer = '';
    currentLine = document.createElement('pre');
    currentLine.className = 'terminal-line';
    currentLine.innerHTML = '<span class="t-prompt">psh&gt; </span><span class="t-input"></span><span class="t-cursor"> </span>';
    body.appendChild(currentLine);
    body.scrollTop = body.scrollHeight;
  }

  function updateCurrentLine() {
    currentLine.querySelector('.t-input').textContent = buffer;
    body.scrollTop = body.scrollHeight;
  }

  // intro
  appendLine('Welcome to psh! Type "help" for commands.');
  appendLine('');
  newPrompt();

  document.addEventListener('keydown', (e) => {
    const overlay = document.getElementById('terminal-overlay');
    if (!overlay.classList.contains('open')) return;

    if (!currentLine) return;

    if (e.ctrlKey && e.key === 'c') {
      e.preventDefault();
      currentLine.querySelector('.t-cursor').remove();
      currentLine.querySelector('.t-input').textContent = buffer + ' ^C';
      newPrompt();
      return;
    }

    if (e.key === 'Enter') {
      const cmd = buffer.trim();
      currentLine.querySelector('.t-cursor').remove();
      buffer = '';

      if (!cmd) {
        newPrompt();
        return;
      }

      const result = shell.execute(cmd);

      if (result === 'CLEAR') {
        body.innerHTML = '';
        newPrompt();
        return;
      }

      if (result) appendLine(result);
      newPrompt();
      return;
    }

    if (e.key === 'Backspace') {
      buffer = buffer.slice(0, -1);
      updateCurrentLine();
      return;
    }

    // ignore modifier-only keys
    if (e.key.length > 1) return;

    buffer += e.key;
    updateCurrentLine();
  });

  terminal.addEventListener('click', () => {
    terminal.focus();
  });
</script>