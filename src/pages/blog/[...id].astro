---
import Layout from '../../layouts/Layout.astro'
import CenteredLayout from '../../layouts/CenteredLayout.astro'
import NavBar from '../../components/NavBar.astro'
import Box from '../../components/Box.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
    const posts = await getCollection('blog')
    return posts.map(post => ({
        params: { id: post.id },
        props: { post },
    }))
}

const { post } = Astro.props
const { Content } = await render(post)

const words = post.body?.split(' ').length
const readTime = Math.ceil(words / 200)

const date = new Date(post.data.date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
})
---

<Layout>
    <CenteredLayout>
        <NavBar />

        <div class="prose dark:prose-invert max-w-none pt-10">
            <Box>
                <h1 class="pb-0 mb-0">{post.data.title}</h1>
                <p class="italic">{date} · {readTime} minute read</p>
                <hr/>
                <Content />
            </Box>
        </div>
    </CenteredLayout>
</Layout>

<style is:global>
    .prose code {
        background-color: #232221;
        padding: 0.2rem 0.4rem;
        border-radius: 0.2rem;
        font-weight: normal;
    }

    [data-theme='light'] .prose code {
        background-color: #d3cac0;
    }

    .prose code::before,
    .prose code::after {
        content: "";
    }

    .prose pre code {
        all: unset !important;
    }

    .astro-code {
        background-color: #1a1a17 !important;
        padding: 1rem;
        border-radius: 8px;
    }
</style>
