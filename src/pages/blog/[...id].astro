---
import Layout from '../../layouts/Layout.astro'
import CenteredLayout from '../../layouts/CenteredLayout.astro'
import NavBar from '../../components/NavBar.astro'
import Box from '../../components/Box.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
    const posts = await getCollection('blog')
    return posts.map(post => ({
        params: { id: post.id },
        props: { post },
    }))
}

const { post } = Astro.props
const { Content } = await render(post)

const words = post.body?.split(' ').length
const readTime = Math.ceil(words / 200)

const date = new Date(post.data.date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
})
---

<Layout>
    <CenteredLayout>
        <NavBar />

        <div class="prose dark:prose-invert max-w-none pt-10">
            <Box>
                <h1 class="pb-0 mb-0">{post.data.title}</h1>
                <p class="italic">{date} · {readTime} minute read</p>
                <hr/>
                <Content />
            </Box>
        </div>
    </CenteredLayout>
</Layout>
