---
import Layout from '../../layouts/Layout.astro'
import CenteredLayout from '../../layouts/CenteredLayout.astro'
import NavBar from '../../components/NavBar.astro'
import Box from '../../components/Box.astro'

import { getCollection } from 'astro:content'
const posts = await getCollection('blog')
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout>
    <CenteredLayout>
        <NavBar />

        <div class="grid gap-3">
            {posts.map(post => {
                const date = new Date(post.data.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                })
                return (
                    <Box>
                        <a href={`/blog/${post.id}`} class="flex flex-col gap-2">
                            <div class="flex flex-row justify-between items-center">
                                <h2 class="text-2xl font-bold">{post.data.title}</h2>
                                <span class="text-sm opacity-60">{date}</span>
                            </div>
                            <p class="opacity-80">{post.data.description}</p>
                        </a>
                    </Box>
                )
            })}
        </div>
    </CenteredLayout>
</Layout>

